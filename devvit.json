{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "queuelens",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Analyze with QueueLens",
        "description": "Open an evidence-backed QueueLens review card for this post or comment.",
        "location": "post",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/analyze-with-queuelens"
      },
      {
        "label": "Analyze with QueueLens",
        "description": "Open an evidence-backed QueueLens review card for this post or comment.",
        "location": "comment",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/analyze-with-queuelens"
      }
    ]
  },
  "permissions": {
    "reddit": {
      "enable": true,
      "scope": "moderator"
    },
    "http": {
      "enable": true,
      "domains": ["api.openai.com"]
    },
    "redis": true
  },
  "settings": {
    "global": {
      "openaiApiKey": {
        "type": "string",
        "label": "OpenAI API key",
        "isSecret": true
      },
      "openaiModel": {
        "type": "string",
        "label": "OpenAI model id",
        "defaultValue": "gpt-4o-mini"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "queuelens_dev"
  }
}
